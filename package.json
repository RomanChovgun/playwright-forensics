{
  "name": "playwright-forensics",
  "version": "0.2.0-rc.1",
  "description": "Evidence-based Playwright failure analysis from trace.zip, DOM snapshots, network, and console data",
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "engines": {
    "node": ">=18",
    "npm": ">=9"
  },
  "bin": {
    "pwf": "dist/cli.js"
  },
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "default": "./dist/index.js"
    },
    "./fixtures": {
      "types": "./dist/fixtures.d.ts",
      "default": "./dist/fixtures.js"
    },
    "./reporter": {
      "types": "./dist/reporter/reporter.d.ts",
      "default": "./dist/reporter/reporter.js"
    },
    "./package.json": "./package.json"
  },
  "files": [
    "dist",
    "README.md",
    "LICENSE"
  ],
  "sideEffects": false,
  "scripts": {
    "build": "tsc",
    "clean": "rm -rf dist test-results",
    "prebuild": "npm run clean",
    "test": "playwright test",
    "test:ci": "playwright test",
    "typecheck": "tsc --noEmit",
    "test:hardening": "playwright test test/scenarios/unit.spec.ts test/scenarios/hardening.spec.ts",
    "test:trace-cli": "node test/smoke-trace-cli.mjs",
    "pack:check": "npm pack --dry-run",
    "test:headed": "playwright test --headed",
    "test:report": "playwright test --reporter=html",
    "dev": "tsc --watch",
    "prepublishOnly": "npm run build",
    "preversion": "npm run build && npm test"
  },
  "peerDependencies": {
    "@playwright/test": ">=1.40"
  },
  "optionalDependencies": {
    "chokidar": "^4.0.3"
  },
  "devDependencies": {
    "@playwright/test": "^1.52.0",
    "@types/node": "^22.15.0",
    "typescript": "^5.8.0"
  },
  "keywords": [
    "playwright",
    "forensics",
    "debugging",
    "test-failure",
    "dom-analysis",
    "e2e",
    "testing",
    "automation",
    "quality-assurance"
  ],
  "license": "MIT",
  "publishConfig": {
    "access": "public",
    "provenance": true
  },
  "author": "Roman Chovgun (https://t.me/romanchovgun)",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/RomanChovgun/playwright-forensics.git"
  },
  "bugs": {
    "url": "https://github.com/RomanChovgun/playwright-forensics/issues"
  },
  "homepage": "https://github.com/RomanChovgun/playwright-forensics#readme",
  "dependencies": {
    "fflate": "^0.8.3"
  },
  "directories": {
    "test": "test"
  }
}
